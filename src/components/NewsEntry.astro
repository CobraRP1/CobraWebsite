---
import type { NewsItem } from '../lib/types';
import { formatDate } from '../lib/content';
import { href } from '../lib/site';

interface Props {
  item: NewsItem;
  /** Show the photo gallery (on /news/); the homepage band keeps it compact. */
  showImages?: boolean;
}

const { item, showImages = false } = Astro.props;
const date = formatDate(item.date);
const images = item.images ?? [];
const linkHref = item.link ? href(item.link) : null;
---

<article class="news-item">
  {date && <p class="date muted">{date}</p>}
  <h3>
    {linkHref ? <a href={linkHref} rel={item.link?.startsWith('http') ? 'noopener' : undefined}>{item.title}</a> : item.title}
  </h3>
  {item.body && <p class="body">{item.body}</p>}

  {
    showImages && images.length > 0 && (
      <figure class="gallery">
        <div class="grid">
          {images.map((src, i) => (
            <img src={href(src)} alt={`${item.title} — photo ${i + 1}`} loading="lazy" />
          ))}
        </div>
        {item.credit && <figcaption class="muted">{item.credit}</figcaption>}
      </figure>
    )
  }
</article>

<style>
  .news-item {
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .date {
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h3 {
    font-size: var(--text-base);
    margin-top: var(--space-1);
  }

  h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .body {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    max-width: var(--prose-width);
  }

  .gallery {
    margin-top: var(--space-4);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr));
    gap: var(--space-2);
  }

  .grid img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: var(--radius);
  }

  figcaption {
    margin-top: var(--space-2);
    font-size: var(--text-xs);
  }
</style>
