---
import { site } from '../lib/content';
import { href, isActive } from '../lib/site';

const current = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="wordmark" href={href('/')}>
      {
        /* TODO(Cobra): once the official logo is in public/assets/ and set in
           site.yaml, this renders the image instead of the text wordmark. */
        site.logo ? (
          <img src={href(site.logo)} alt={site.name} height="40" />
        ) : (
          <span class="wordmark-text">
            <span class="wordmark-short">{site.shortName}</span>
            <span class="wordmark-long">{site.name}</span>
          </span>
        )
      }
    </a>

    <nav aria-label="Primary">
      <ul>
        {
          site.nav.map((item) => (
            <li>
              <a
                href={href(item.path)}
                aria-current={isActive(item.path, current) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    padding-block: var(--space-4);
    flex-wrap: wrap;
  }

  .wordmark {
    color: var(--color-text);
    text-decoration: none;
  }

  .wordmark-text {
    display: flex;
    flex-direction: column;
  }

  .wordmark-short {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .wordmark-long {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.3;
    max-width: 22rem;
  }

  nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  nav a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    padding-block: var(--space-1);
    border-bottom: 2px solid transparent;
  }

  nav a:hover {
    color: var(--color-text);
  }

  nav a[aria-current='page'] {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
  }

  @media (max-width: 720px) {
    .header-inner {
      gap: var(--space-4);
    }

    .wordmark-long {
      display: none;
    }

    nav ul {
      gap: var(--space-4);
    }
  }
</style>
