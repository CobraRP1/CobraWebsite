---
import type { EventItem } from '../lib/types';
import { formatDate } from '../lib/content';
import { href } from '../lib/site';

interface Props {
  event: EventItem;
}

const { event } = Astro.props;

const start = formatDate(event.date);
const end = formatDate(event.endDate);
const when = event.dateText ?? (start && end ? `${start} – ${end}` : start);
const materials = event.materials ?? [];
const recordings = event.recordings ?? [];
---

<article class="event">
  <div class="when">
    {when ? <p class="date">{when}</p> : <p class="date muted">Date to be announced</p>}
    {event.kind && <p class="kind muted">{event.kind}</p>}
  </div>

  <div class="what">
    <h3>
      {event.link ? <a href={event.link} rel="noopener">{event.title}</a> : event.title}
      {event.note && <span class="note">{event.note}</span>}
    </h3>
    {event.location && <p class="location muted">{event.location}</p>}
    {event.image && <img class="event-image" src={href(event.image)} alt={event.title} loading="lazy" />}
    {
      event.description &&
      event.description
        .split(/\n\s*\n/)
        .map((paragraph) => <p class="description">{paragraph}</p>)
    }

    {
      materials.length > 0 && (
        <div class="extras">
          <h4>Materials</h4>
          <ul>
            {materials.map((m) => (
              <li>
                <a href={href(m.file)}>{m.label}</a>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      recordings.length > 0 && (
        <div class="extras">
          <h4>Recordings</h4>
          <ul>
            {recordings.map((r) => (
              <li>
                {/* External links (YouTube) — deliberately links, never embeds. */}
                <a href={r.url} rel="noopener">{r.label} ↗</a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>
</article>

<style>
  .event {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: var(--space-6);
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .date {
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .kind {
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h3 {
    font-size: var(--text-lg);
  }

  h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .note {
    display: inline-block;
    margin-left: var(--space-2);
    padding: 0.1em 0.6em;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--color-text-muted);
    vertical-align: middle;
    white-space: nowrap;
  }

  .location {
    font-size: var(--text-sm);
  }

  .event-image {
    margin-top: var(--space-4);
    max-width: 28rem;
    border-radius: var(--radius);
  }

  .description {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    max-width: var(--prose-width);
  }

  .extras {
    margin-top: var(--space-4);
  }

  .extras h4 {
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .extras ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .extras a {
    font-size: var(--text-sm);
  }

  @media (max-width: 720px) {
    .event {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>
