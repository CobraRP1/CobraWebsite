---
import type { EventItem } from '../lib/types';
import { formatDate } from '../lib/content';

interface Props {
  event: EventItem;
}

const { event } = Astro.props;

const start = formatDate(event.date);
const end = formatDate(event.endDate);
const when = start && end ? `${start} – ${end}` : start;
---

<article class="event">
  <div class="when">
    {when ? <p class="date">{when}</p> : <p class="date muted">Date to be announced</p>}
    {event.kind && <p class="kind muted">{event.kind}</p>}
  </div>

  <div class="what">
    <h3>
      {event.link ? <a href={event.link} rel="noopener">{event.title}</a> : event.title}
    </h3>
    {event.location && <p class="location muted">{event.location}</p>}
    {event.description && <p class="description">{event.description}</p>}
  </div>
</article>

<style>
  .event {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: var(--space-6);
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .date {
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .kind {
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h3 {
    font-size: var(--text-lg);
  }

  h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .location {
    font-size: var(--text-sm);
  }

  .description {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    max-width: var(--prose-width);
  }

  @media (max-width: 720px) {
    .event {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>
