---
import Base from '../layouts/Base.astro';
import NewsEntry from '../components/NewsEntry.astro';
import EventEntry from '../components/EventEntry.astro';
import Placeholder from '../components/Placeholder.astro';
import { site, about, news, events, splitEvents } from '../lib/content';
import { href } from '../lib/site';

const { upcoming } = splitEvents(events);
const latestNews = news.slice(0, 3);
const nextEvents = upcoming.slice(0, 2);
---

<Base>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">{site.name}</p>
      <h1>{site.tagline}</h1>
      <p class="lede prose">{site.description}</p>
      <p class="cta">
        <a href={href('/about/')}>About the center</a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Explore COBRA</h2>
      <div class="explore-grid">
        {
          site.nav.map((item) => (
            <a class="tile" href={href(item.path)}>
              {item.image && <img src={href(item.image)} alt="" loading="lazy" />}
              <div class="tile-text">
                <h3>{item.label}</h3>
                {item.blurb && <p class="muted">{item.blurb}</p>}
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div>
        <h2 class="section-title">In the Spotlight</h2>
        {
          latestNews.length > 0 ? (
            <div>
              {latestNews.map((item) => (
                <NewsEntry item={item} />
              ))}
              <p class="more">
                <a href={href('/news/')}>All news →</a>
              </p>
            </div>
          ) : (
            <Placeholder note="No news items yet. Add them to src/data/news.yaml." />
          )
        }
      </div>

      <div>
        <h2 class="section-title">Upcoming</h2>
        {
          nextEvents.length > 0 ? (
            <div>
              {nextEvents.map((event) => (
                <EventEntry event={event} />
              ))}
              <p class="more">
                <a href={href('/events/')}>All events →</a>
              </p>
            </div>
          ) : (
            <Placeholder note="No upcoming events. Add them to src/data/events.yaml; past events move to the archive automatically." />
          )
        }
      </div>
    </div>
  </section>

  <div class="banner">
    <img src={href('/assets/banner-home.jpg')} alt="" loading="lazy" />
  </div>

  <section class="section">
    <div class="container">
      <h2 class="section-title">What We Do</h2>
      {
        about.intro ? (
          <div class="prose">
            <p>{about.intro}</p>
            <p class="more">
              <a href={href('/about/')}>More about COBRA →</a>
            </p>
          </div>
        ) : (
          <Placeholder note="Add `intro` in src/data/about.yaml." />
        )
      }
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: var(--space-24) var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .hero h1 {
    max-width: 22ch;
  }

  .hero .lede {
    margin-top: var(--space-6);
  }

  .cta {
    margin-top: var(--space-8);
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--space-6);
  }

  .tile {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s ease;
  }

  .tile:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .tile img {
    width: 100%;
    aspect-ratio: 47 / 27;
    object-fit: cover;
  }

  .tile-text {
    padding: var(--space-4) var(--space-6) var(--space-6);
  }

  .tile h3 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
  }

  .tile p {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
  }

  .banner img {
    width: 100%;
    display: block;
  }

  .more {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
  }

  .more a {
    text-decoration: none;
  }

  .more a:hover {
    text-decoration: underline;
  }

  @media (max-width: 720px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .hero {
      padding-block: var(--space-16) var(--space-12);
    }
  }
</style>
