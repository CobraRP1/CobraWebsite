---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import Placeholder from '../components/Placeholder.astro';
import { business, site } from '../lib/content';
---

<Base title="Business" description={`How ${site.shortName} collaborates with businesses: research-driven insights on regulation, taxation, and disclosure.`}>
  <PageHeader title={business.title} lede={business.intro} />

  <section class="section">
    <div class="container prose">
      <h2 class="section-title">{business.insights.title}</h2>
      {business.insights.paragraphs.map((p) => <p class="para">{p}</p>)}
      <p class="list-label">{business.insights.listLabel}</p>
      <ul class="bullets">
        {business.insights.items.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container prose">
      <h2 class="section-title">{business.collaborate.title}</h2>
      {business.collaborate.paragraphs.map((p) => <p class="para">{p}</p>)}
      <p class="list-label">{business.collaborate.listLabel}</p>
      <ul class="bullets">
        {business.collaborate.items.map((item) => <li>{item}</li>)}
      </ul>
      {
        site.email ? (
          <p class="para">
            Get in touch with us via <a href={`mailto:${site.email}`}>{site.email}</a>
          </p>
        ) : (
          <Placeholder note="Contact email pending — see site.yaml." />
        )
      }
    </div>
  </section>
</Base>

<style>
  .para {
    margin-top: var(--space-4);
  }

  .para:first-of-type {
    margin-top: 0;
  }

  .list-label {
    margin-top: var(--space-6);
    font-weight: 600;
    font-size: var(--text-sm);
  }

  .bullets {
    margin-top: var(--space-3);
    padding-left: 1.2em;
    list-style: disc;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }
</style>
