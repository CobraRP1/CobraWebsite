---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import Placeholder from '../components/Placeholder.astro';
import { legal, site } from '../lib/content';

const todo = (value: string | null, what: string) => value ?? `[${what} — TODO(Cobra)]`;
---

<Base title="Datenschutzerklärung" description={`Datenschutzerklärung — ${site.name}.`}>
  <PageHeader title="Datenschutzerklärung" />

  <section class="section">
    <div class="container prose stack">
      <Placeholder note="DRAFT — NOT LEGAL ADVICE. Drafted by Claude and unreviewed. It describes what this site ACTUALLY does today: a static site on GitHub Pages, self-hosted fonts, no cookies, no analytics, no third-party requests. If any of that changes — above all switching GoatCounter on in site.yaml — this page must be updated in the SAME commit. Before launch, check whether the University of Mannheim's central Datenschutzerklärung covers Cobra, and have this reviewed." />

      <h2>Verantwortliche Stelle</h2>
      <p>
        {todo(legal.operator, 'Verantwortliche Stelle')}<br />
        {todo(legal.address, 'Anschrift')}<br />
        E-Mail: {todo(legal.email, 'E-Mail-Adresse')}
      </p>

      <h2>Datenschutzbeauftragte:r</h2>
      <p>{todo(legal.data_protection_officer, 'Datenschutzbeauftragte:r')}</p>

      <h2>Hosting und Server-Logs</h2>
      <p>{legal.hosting_note}</p>
      <p>
        Diese Verarbeitung erfolgt auf Grundlage unseres berechtigten Interesses an einer
        technisch fehlerfreien Darstellung dieser Website (Art. 6 Abs. 1 lit. f DSGVO). Da der
        Hoster seinen Sitz in den USA hat, findet eine Datenübermittlung in ein Drittland statt.
      </p>

      <h2>Cookies</h2>
      <p>
        Diese Website setzt <strong>keine Cookies</strong> und verwendet weder Local Storage noch
        vergleichbare Techniken zur Wiedererkennung von Besucherinnen und Besuchern.
      </p>

      <h2>Schriftarten</h2>
      <p>
        Die verwendeten Schriftarten werden <strong>lokal von diesem Server ausgeliefert</strong>.
        Es besteht keine Verbindung zu Google Fonts oder anderen externen Anbietern. Beim Aufruf
        dieser Seite werden dadurch keine Daten an Dritte übertragen.
      </p>

      <h2>Analyse-Werkzeuge</h2>
      <p>
        Diese Website verwendet derzeit <strong>keine Analyse- oder Tracking-Werkzeuge</strong>.
      </p>
      <!--
        TODO(Cobra): Wird GoatCounter in site.yaml aktiviert, MUSS dieser Abschnitt im selben
        Commit ersetzt werden: GoatCounter, keine Cookies, keine personenbezogene Speicherung,
        Rechtsgrundlage Art. 6 Abs. 1 lit. f DSGVO, Anbieter und Serverstandort nennen.
      -->

      <h2>Ihre Rechte</h2>
      <p>
        Sie haben jederzeit das Recht auf Auskunft über die zu Ihrer Person gespeicherten
        personenbezogenen Daten (Art. 15 DSGVO), deren Berichtigung (Art. 16 DSGVO), Löschung
        (Art. 17 DSGVO) oder Einschränkung der Verarbeitung (Art. 18 DSGVO), ein
        Widerspruchsrecht gegen die Verarbeitung (Art. 21 DSGVO) sowie ein Recht auf
        Datenübertragbarkeit (Art. 20 DSGVO). Zudem steht Ihnen ein Beschwerderecht bei einer
        Datenschutz-Aufsichtsbehörde zu.
      </p>

      <h2>Kontaktaufnahme</h2>
      <p>
        Wenn Sie uns per E-Mail kontaktieren, werden Ihre Angaben zum Zwecke der Bearbeitung der
        Anfrage und für den Fall von Anschlussfragen gespeichert. Diese Daten geben wir nicht ohne
        Ihre Einwilligung weiter.
      </p>
    </div>
  </section>
</Base>

<style>
  h2 {
    font-size: var(--text-lg);
    margin-top: var(--space-8);
  }

  p {
    font-size: var(--text-sm);
  }
</style>
